# Neon (pooled, sslmode=require)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Better Auth (generate via: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))")
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (optional — leave empty to disable Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Paystack (wired in later milestones)
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
